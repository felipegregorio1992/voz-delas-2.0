# ================================
# Ambiente
# ================================
NODE_ENV=development
PORT=3000

# ================================
# Banco de Dados (MySQL)
# ================================
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="mysql://root:sua_senha@localhost:3306/vozdelas"

# ================================
# JWT
# ================================
# Gere chaves seguras com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=troque_por_uma_chave_aleatoria_longa_minimo_64_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque_por_outra_chave_aleatoria_longa_minimo_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# Rate Limiting (Throttler)
# ================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ================================
# CORS (origens separadas por vírgula)
# ================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ================================
# Chat — Criptografia AES-256
# ================================
# OBRIGATÓRIO: Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mínimo 32 caracteres. O servidor NÃO inicia sem esta variável configurada.
CHAT_ENCRYPTION_KEY=gere_uma_chave_de_64_chars_hex_aqui_obrigatorio

# ================================
# Upload de Arquivos
# ================================
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
MAX_FILE_SIZE=5242880

# ================================
# IA (OpenAI)
# ================================
OPENAI_API_KEY=sua-chave-openai-aqui
