// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum IncidentType {
  VIOLENCE
  HARASSMENT
  THREAT
  OTHER
}

enum IncidentStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum PanicStatus {
  ACTIVE
  ENDED
}

enum AttachmentOwnerType {
  INCIDENT
  PANIC
  ATTENDANCE
}

enum SupportServiceType {
  CEAM
  DEAM
  DEFENSORIA
  OUTRO
}

enum IntegrationProvider {
  TJRJ
  DEAM
  GMAP
  DEFENSORIA
  SEI_DETRAN
}

enum IntegrationJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum MerchantRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  SOLD_OUT
}

enum AttendanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AttendanceType {
  IDENTIFIED
  SEMI_IDENTIFIED
  ANONYMOUS
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ConsentStatus {
  PENDING
  ACCEPTED
  REJECTED
  REVOKED
}

enum VideoSessionStatus {
  PENDING
  ACTIVE
  ENDED
  CANCELLED
}

enum UserSource {
  APP
  WEB
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String?    @unique
  phone        String?    @unique
  passwordHash String
  isActive     Boolean    @default(true)
  source       UserSource @default(APP)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  refreshTokens        RefreshToken[]
  userRoles            UserRole[]
  trustedContacts      TrustedContact[]
  incidents            Incident[]
  panicEvents          PanicEvent[]
  auditLogs            AuditLog[]
  integrationJobs      IntegrationJob[]
  merchantRequest      MerchantRequest?
  merchant             Merchant?
  clientAttendances    Attendance[] @relation("ClientAttendances")
  attendantAttendances Attendance[] @relation("AttendantAttendances")
  chatMessages         ChatMessage[]
  videoSessions        VideoSession[] @relation("ClientVideoSessions")
  attendantVideoSessions VideoSession[] @relation("AttendantVideoSessions")
  referrerReferrals    Referral[] @relation("ReferrerReferrals")
  scheduledAttendances ScheduledAttendance[] @relation("ClientScheduledAttendances")
  attendantScheduledAttendances ScheduledAttendance[] @relation("AttendantScheduledAttendances")
  aiChatMessages       AiChatMessage[]
  eventRegistrations   EventRegistration[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  userRoles UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  label       String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model TrustedContact {
  id           String   @id @default(uuid())
  userId       String
  name         String
  phone        String
  relationship String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trusted_contacts")
}

model Incident {
  id          String         @id @default(uuid())
  userId      String
  type        IncidentType
  description String?
  status      IncidentStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations IncidentLocation[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("incidents")
}

model IncidentLocation {
  id         String   @id @default(uuid())
  incidentId String
  lat        Float
  lng        Float
  accuracy   Float?
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([lat, lng])
  @@map("incident_locations")
}

model PanicEvent {
  id        String      @id @default(uuid())
  userId    String
  status    PanicStatus @default(ACTIVE)
  startedAt DateTime    @default(now())
  endedAt   DateTime?

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations PanicLocation[]

  @@index([userId])
  @@index([status])
  @@index([startedAt])
  @@map("panic_events")
}

model PanicLocation {
  id           String   @id @default(uuid())
  panicEventId String
  lat          Float
  lng          Float
  accuracy     Float?
  createdAt    DateTime @default(now())

  panicEvent PanicEvent @relation(fields: [panicEventId], references: [id], onDelete: Cascade)

  @@index([panicEventId])
  @@index([lat, lng])
  @@map("panic_locations")
}

model Attachment {
  id        String              @id @default(uuid())
  ownerType AttachmentOwnerType
  ownerId   String
  mimeType  String
  size      Int
  url       String
  createdAt DateTime            @default(now())

  @@index([ownerType, ownerId])
  @@map("attachments")
}

model SupportService {
  id        String             @id @default(uuid())
  name      String
  type      SupportServiceType
  phone     String?
  address   String?
  hours     String?
  city      String?
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())

  referrals Referral[]

  @@index([type])
  @@index([city])
  @@index([isActive])
  @@map("support_services")
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  ip          String?
  userAgent   String?
  detailsJson String?  @db.Text
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model IntegrationJob {
  id          String               @id @default(uuid())
  userId      String?
  provider    IntegrationProvider
  payloadJson String               @db.Text
  status      IntegrationJobStatus @default(PENDING)
  attempts    Int                  @default(0)
  lastError   String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([status])
  @@index([createdAt])
  @@map("integration_jobs")
}

model MerchantRequest {
  id              String                @id @default(uuid())
  userId          String                @unique
  businessName    String
  description     String?               @db.Text
  phone           String?
  email           String?
  address         String?
  city            String?
  status          MerchantRequestStatus @default(PENDING)
  rejectionReason String?               @db.Text
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("merchant_requests")
}

model Merchant {
  id           String   @id @default(uuid())
  userId       String   @unique
  businessName String
  description  String?  @db.Text
  phone        String?
  email        String?
  address      String?
  city         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([userId])
  @@index([isActive])
  @@index([city])
  @@map("merchants")
}

model Product {
  id          String        @id @default(uuid())
  merchantId  String
  name        String
  description String?       @db.Text
  price       Float
  imageUrl    String?
  category    String?
  status      ProductStatus @default(ACTIVE)
  stock       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("products")
}

model Attendance {
  id                String            @id @default(uuid())
  clientId          String
  attendantId       String?
  status            AttendanceStatus @default(PENDING)
  type              AttendanceType
  riskLevel         RiskLevel?
  observations      String?           @db.Text
  chatHidden        Boolean           @default(false)
  startedAt         DateTime?
  endedAt           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  client            User              @relation("ClientAttendances", fields: [clientId], references: [id], onDelete: Cascade)
  attendant         User?             @relation("AttendantAttendances", fields: [attendantId], references: [id], onDelete: SetNull)
  form              AttendanceForm?
  consentTerm       ConsentTerm?
  chatMessages      ChatMessage[]
  videoSessions     VideoSession[]
  referrals         Referral[]
  riskClassifications RiskClassification[]
  scheduledAttendance ScheduledAttendance?

  @@index([clientId])
  @@index([attendantId])
  @@index([status])
  @@index([createdAt])
  @@map("attendances")
}

model AttendanceForm {
  id              String    @id @default(uuid())
  attendanceId    String    @unique
  formData        String    @db.Text
  isComplete      Boolean   @default(false)
  savedAt         DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  attendance      Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([isComplete])
  @@map("attendance_forms")
}

model ConsentTerm {
  id              String        @id @default(uuid())
  attendanceId    String        @unique
  status          ConsentStatus @default(PENDING)
  acceptedAt      DateTime?
  revokedAt       DateTime?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  attendance      Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([status])
  @@map("consent_terms")
}

model ChatMessage {
  id          String    @id @default(uuid())
  attendanceId String
  senderId    String
  message     String    @db.Text
  isEncrypted Boolean   @default(true)
  createdAt   DateTime  @default(now())

  attendance  Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  sender      User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([senderId])
  @@index([createdAt])
  @@map("chat_messages")
}

model VideoSession {
  id            String              @id @default(uuid())
  attendanceId  String
  clientId      String
  attendantId  String
  status        VideoSessionStatus  @default(PENDING)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  attendance    Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  client        User       @relation("ClientVideoSessions", fields: [clientId], references: [id], onDelete: Cascade)
  attendant     User       @relation("AttendantVideoSessions", fields: [attendantId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([clientId])
  @@index([attendantId])
  @@index([status])
  @@map("video_sessions")
}

model RiskClassification {
  id            String    @id @default(uuid())
  attendanceId  String
  riskLevel     RiskLevel
  notes         String?   @db.Text
  classifiedBy  String
  classifiedAt  DateTime  @default(now())

  attendance    Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([riskLevel])
  @@index([classifiedAt])
  @@map("risk_classifications")
}

model Referral {
  id            String   @id @default(uuid())
  attendanceId  String
  serviceId     String
  referredBy    String
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  attendance    Attendance    @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  service       SupportService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  referrer      User          @relation("ReferrerReferrals", fields: [referredBy], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([serviceId])
  @@index([createdAt])
  @@map("referrals")
}

model ScheduledAttendance {
  id            String               @id @default(uuid())
  clientId      String
  attendantId   String?
  scheduledFor  DateTime
  serviceType   ScheduleServiceType?
  notes         String?              @db.Text
  status        String               @default("PENDING")
  attendanceId  String?              @unique
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  client        User          @relation("ClientScheduledAttendances", fields: [clientId], references: [id], onDelete: Cascade)
  attendant     User?         @relation("AttendantScheduledAttendances", fields: [attendantId], references: [id], onDelete: SetNull)
  attendance    Attendance?   @relation(fields: [attendanceId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([attendantId])
  @@index([scheduledFor])
  @@index([status])
  @@index([serviceType])
  @@map("scheduled_attendances")
}

model OperatingHours {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0=Domingo, 1=Segunda, ..., 6=Sábado
  openTime  String   // "HH:MM"
  closeTime String   // "HH:MM"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dayOfWeek])
  @@map("operating_hours")
}

model AiChatMessage {
  id        String   @id @default(uuid())
  userId    String
  userMsg   String   @db.Text
  aiReply   String   @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("ai_chat_messages")
}

enum AnnouncementType {
  BANNER
  NOTICE
}

enum ScheduleServiceType {
  ASSISTENCIA_SOCIAL
  ADVOCACIA
  PSICOLOGIA
  NUTRICAO
  FISIOTERAPIA
  AURICULOTERAPIA
  TERAPIA_GRUPO
  SALAO_BELEZA
  ATIVIDADE_FISICA
  ATIVIDADE_COLETIVA
  DEFESA_PESSOAL
  CAIMO
  OUTRO
}

enum EventCategory {
  COURSE
  WORKSHOP
  PHYSICAL_ACTIVITY
  CULTURAL
  HEALTH
  ENTREPRENEURSHIP
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventRegistrationStatus {
  CONFIRMED
  CANCELLED
  WAITLIST
}

model Announcement {
  id        String           @id @default(uuid())
  title     String
  content   String?          @db.Text
  imageUrl  String?
  linkUrl   String?
  type      AnnouncementType
  isActive  Boolean          @default(true)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  dismissals AnnouncementDismissal[]

  @@index([type])
  @@index([isActive])
  @@index([startDate, endDate])
  @@map("announcements")
}

model AnnouncementDismissal {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
  @@map("announcement_dismissals")
}


model Event {
  id            String        @id @default(uuid())
  title         String
  description   String?       @db.Text
  category      EventCategory
  status        EventStatus   @default(PUBLISHED)
  location      String?
  imageUrl      String?
  startDate     DateTime
  endDate       DateTime?
  startTime     String?       // "HH:MM"
  endTime       String?       // "HH:MM"
  maxSlots      Int?          // null = sem limite
  isRecurring   Boolean       @default(false)
  recurringDays String?       // JSON: [1,3,5] para Seg,Qua,Sex
  sector        String?       // "SEDE", "CASA_DA_MULHER"
  program       String?       // "ELA_EM_MOVIMENTO", "ELA_NA_CULTURA", etc.
  createdBy     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  registrations EventRegistration[]

  @@index([category])
  @@index([status])
  @@index([startDate])
  @@index([sector])
  @@map("events")
}

model EventRegistration {
  id        String                  @id @default(uuid())
  eventId   String
  userId    String
  status    EventRegistrationStatus @default(CONFIRMED)
  notes     String?
  createdAt DateTime                @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@index([status])
  @@map("event_registrations")
}

model SupportTotem {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  address     String
  lat         Float
  lng         Float
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([lat, lng])
  @@map("support_totems")
}
